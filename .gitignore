# R session state ----------------------------------------------------------
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# renv: never commit the package library, sandbox, or staging area; the
# lockfile is what makes the project reproducible.
renv/library/
renv/staging/
renv/sandbox/
renv/local/

# Generated analytical frames; rebuilt by R/run_all.R from the database.
output/frames/
output/frames/*.rds

# Generated charts, workbook, and PDFs; rebuilt by R/run_all.R.
output/charts/
output/*.xlsx
output/*.pdf
output/*.md

# Rendered Quarto output; rebuilt by quarto render.
quarto/*.html
quarto/*.pdf

# Legacy SQLite artifacts (no longer generated; kept in case of stale copies).
data/*.db
data/*.db-wal
data/*.db-shm
data/*.db.bak
data/*.db.bak-*

# Three sibling project directories that happen to live in this folder
# but are independent repos with their own remotes.
MsShawnP/
retail-velocity-decision-tool/
velocity-tool/

# Environment
.Renviron
.env

# Quarto / LaTeX intermediate state
.quarto/
*.aux
*.log
*.toc
*.out
*.synctex.gz

# Dev-only diagnostic scripts (not part of the main pipeline).
R/_*
working/
inspect_db.py
check_db.R

# Shiny deployment metadata (account-specific, not portable).
shiny/rsconnect/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Secrets and credentials — never commit these.
.env
.env.*
.Renviron
*.pem
*.key
*.pfx
*.p12
credentials*
.secret*

# Workflow state files (dev scaffolding, not portfolio content).
AUDIT.md
PLAN.md
HANDOFF.md
DECISIONS.md
FAILURES.md

# OS noise
.DS_Store
Thumbs.db
