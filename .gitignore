# R session state ----------------------------------------------------------
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# renv: never commit the package library, sandbox, or staging area; the
# lockfile is what makes the project reproducible.
renv/library/
renv/staging/
renv/sandbox/
renv/local/

# Generated analytical frames; rebuilt by R/run_all.R from the database.
# raw_tables.rds is committed so CI can run without Postgres.
output/frames/*
!output/frames/raw_tables.rds

# Generated charts, workbook, PDFs, and build logs; rebuilt by R/run_all.R.
output/charts/
output/*.xlsx
output/*.pdf
output/*.md
output/*.txt
output/frames_baseline/
output/dashboard_screenshots/
output/pdf_pages/

# Rendered Quarto output; rebuilt by quarto render.
quarto/*.html
quarto/*.pdf

# Quarto self-contained JS/CSS lib dependencies (reactable, htmlwidgets, react,
# core-js, etc.); regenerated on every render.
quarto/report_files/libs/

# Data directory: SQLite exports and legacy artifacts.
data/*.db
data/*.db-wal
data/*.db-shm
data/cinderhaven-data/
data/*.db.bak
data/*.db.bak-*

# Three sibling project directories that happen to live in this folder
# but are independent repos with their own remotes.
MsShawnP/
retail-velocity-decision-tool/
velocity-tool/

# Environment
.Renviron
.Renviron.*
.env

# Quarto / LaTeX intermediate state
.quarto/
*.aux
*.log
*.toc
*.out
*.synctex.gz

# Dev-only diagnostic scripts (not part of the main pipeline).
R/_*
working/
inspect_db.py
check_db.R

# Shiny deployment metadata (account-specific, not portable).
shiny/rsconnect/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Secrets and credentials — never commit these.
.env
.env.*
.Renviron
*.pem
*.key
*.pfx
*.p12
credentials*
.secret*

# Workflow state files (dev scaffolding, not portfolio content).
AUDIT.md
PLAN.md
HANDOFF.md
DECISIONS.md
FAILURES.md

# Claude Code session artifacts
.claude/

# Quarto freeze cache
quarto/_freeze/

# Temporary files
report_full_tmp.txt
report_full.txt
*report_full*.txt

# Security - secret leak prevention
secrets.*

# OS noise
.DS_Store
Thumbs.db
